generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                   Int                   @id @default(autoincrement())
  name                 String
  domain               String?               @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  companys             Company[]
  members              TenantMember[]
  contracts            Contract[]
  sites                Site[]
  equipments           Equipment[]
  projects             Project[]
  phases               Phase[]
  tasks                Task[]
  interventions        Intervention[]
  comments             Comment[]
  notifications        Notification[]
  documents            Document[]
  auditlogs            AuditLog[]
  maintenanceschedules MaintenanceSchedule[]
  invoices             Invoice[]
  invoiceitems         InvoiceItem[]
  squads               Squad[]
  meetings             Meeting[]
  purchaserequests     PurchaseRequest[]
  fixedassets          FixedAsset[]
  amortizationlogs     AmortizationLog[]
  vehicles             Vehicle[]
  fuellogs             FuelLog[]
  vehiclemissions      VehicleMission[]
  servicerequests      ServiceRequest[]
  suppliers            Supplier[]
  officesupplys        OfficeSupply[]
  companyspaces        CompanySpace[]
  customRoles          CustomRole[]

  @@map("tenants")
}

model Company {
  id           Int        @id @default(autoincrement())
  name         String
  address      String?
  phone        String?
  email        String?
  logo         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  city         String?
  country      String?
  mf           String?
  primaryColor String?
  rc           String?
  website      String?
  contracts    Contract[]
  invoices     Invoice[]  @relation("ClientInvoices")
  users        User[]
  meetings     Meeting[]
  tenantId     Int?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("companies")
}

model User {
  id                                  Int                   @id @default(autoincrement())
  name                                String
  email                               String                @unique
  password                            String
  role                                Role                  @default(TECHNICIEN)
  phone                               String?
  avatar                              String?
  isActive                            Boolean               @default(true)
  companyId                           Int?
  refreshToken                        String?               @db.Text
  createdAt                           DateTime              @default(now())
  updatedAt                           DateTime              @updatedAt
  auditLogs                           AuditLog[]
  comments                            Comment[]
  documents                           Document[]
  assignedInterventions               Intervention[]        @relation("AssignedInterventions")
  interventionsRequested              Intervention[]        @relation("RequestedInterventions")
  maintenanceSchedules                MaintenanceSchedule[]
  notifications                       Notification[]
  phases                              Phase[]               @relation("PhaseOwner")
  projects                            Project[]             @relation("ProjectManager")
  sites                               Site[]                @relation("SiteManager")
  tasksAssigned                       Task[]                @relation("AssignedTasks")
  tasksCreated                        Task[]                @relation("CreatedTasks")
  company                             Company?              @relation(fields: [companyId], references: [id])
  ledSquads                           Squad[]               @relation("SquadLeader")
  memberOf                            Squad[]               @relation("SquadMembers")
  meetingsCreated                     Meeting[]             @relation("CreatedMeetings")
  meetingsParticipating               Meeting[]             @relation("MeetingParticipants")
  purchaseRequestsCreated             PurchaseRequest[]     @relation("PurchaseRequestCreator")
  purchaseRequestsCommercialValidated PurchaseRequest[]     @relation("PurchaseRequestCommercialValidator")
  purchaseRequestsDirectorValidated   PurchaseRequest[]     @relation("PurchaseRequestDirectorValidator")
  purchaseRequestsPurchased           PurchaseRequest[]     @relation("PurchaseRequestPurchaser")
  assetsInCustody                     FixedAsset[]          @relation("AssetCustodian")
  drivenVehicles                      Vehicle[]             @relation("VehicleDriver")
  vehicleMissions                     VehicleMission[]      @relation("MissionDriver")
  tenantAccess                        TenantMember[]
  customRoleId                        Int?
  customRole                          CustomRole?           @relation(fields: [customRoleId], references: [id])

  @@index([companyId], map: "users_companyId_fkey")
  @@map("users")
}

model TenantMember {
  userId   Int
  tenantId Int
  role     Role @default(TECHNICIEN)
  customRoleId Int?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customRole CustomRole? @relation(fields: [customRoleId], references: [id])

  @@id([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_members")
}

model CustomRole {
  id          Int      @id @default(autoincrement())
  name        String
  permissions Json     
  tenantId    Int?     
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  users       User[]
  tenantMembers TenantMember[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([name, tenantId])
  @@index([tenantId])
  @@map("custom_roles")
}

model Contract {
  id          Int            @id @default(autoincrement())
  name        String
  reference   String?        @unique
  clientId    Int
  startDate   DateTime
  endDate     DateTime
  slaHours    Int            @default(24)
  status      ContractStatus @default(ACTIF)
  description String?        @db.Text
  value       Decimal?       @db.Decimal(10, 2)
  maxHours    Int?           @default(0)
  usedHours   Float?         @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  type        String?
  client      Company        @relation(fields: [clientId], references: [id])
  projects    Project[]
  sites       Site[]
  tenantId    Int?
  tenant      Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([clientId], map: "contracts_clientId_fkey")
  @@index([tenantId])
  @@map("contracts")
}

model Site {
  id                   Int                   @id @default(autoincrement())
  name                 String
  address              String?
  city                 String?
  latitude             Float?
  longitude            Float?
  type                 SiteType              @default(BATIMENT)
  contractId           Int?
  managerId            Int?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  contactName          String?
  contactPhone         String?
  equipment            Equipment[]
  interventions        Intervention[]
  maintenanceSchedules MaintenanceSchedule[]
  contract             Contract?             @relation(fields: [contractId], references: [id])
  manager              User?                 @relation("SiteManager", fields: [managerId], references: [id])
  tasks                Task[]
  meetings             Meeting[]
  purchaseRequests     PurchaseRequest[]
  fixedAssets          FixedAsset[]
  vehicles             Vehicle[]
  serviceRequests      ServiceRequest[]
  companySpaces        CompanySpace[]
  tenantId             Int?
  tenant               Tenant?               @relation(fields: [tenantId], references: [id])

  @@index([contractId], map: "sites_contractId_fkey")
  @@index([managerId], map: "sites_managerId_fkey")
  @@index([tenantId])
  @@map("sites")
}

model Equipment {
  id                   Int                   @id @default(autoincrement())
  name                 String
  type                 String
  brand                String?
  model                String?
  serialNumber         String?
  qrCode               String?               @unique
  status               EquipmentStatus       @default(OPERATIONNEL)
  siteId               Int
  installDate          DateTime?
  warrantyEnd          DateTime?
  notes                String?               @db.Text
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  site                 Site                  @relation(fields: [siteId], references: [id])
  interventions        Intervention[]
  maintenanceSchedules MaintenanceSchedule[]
  tenantId             Int?
  tenant               Tenant?               @relation(fields: [tenantId], references: [id])

  @@index([siteId], map: "equipment_siteId_fkey")
  @@index([tenantId])
  @@map("equipment")
}

model Project {
  id               Int               @id @default(autoincrement())
  name             String
  description      String?           @db.Text
  contractId       Int?
  managerId        Int?
  startDate        DateTime?
  endDate          DateTime?
  progress         Int               @default(0)
  status           ProjectStatus     @default(EN_COURS)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  phases           Phase[]
  contract         Contract?         @relation(fields: [contractId], references: [id])
  manager          User?             @relation("ProjectManager", fields: [managerId], references: [id])
  meetings         Meeting[]
  purchaseRequests PurchaseRequest[]
  tenantId         Int?
  tenant           Tenant?           @relation(fields: [tenantId], references: [id])

  @@index([contractId], map: "projects_contractId_fkey")
  @@index([managerId], map: "projects_managerId_fkey")
  @@index([tenantId])
  @@map("projects")
}

model Phase {
  id        Int       @id @default(autoincrement())
  name      String
  projectId Int
  ownerId   Int?
  order     Int       @default(0)
  startDate DateTime?
  endDate   DateTime?
  progress  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User?     @relation("PhaseOwner", fields: [ownerId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
  tenantId  Int?
  tenant    Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([ownerId], map: "phases_ownerId_fkey")
  @@index([projectId], map: "phases_projectId_fkey")
  @@index([tenantId])
  @@map("phases")
}

model Task {
  id                  Int        @id @default(autoincrement())
  title               String
  description         String?    @db.Text
  status              TaskStatus @default(A_FAIRE)
  priority            Priority   @default(NORMALE)
  createdById         Int?
  siteId              Int?
  phaseId             Int?
  dueDate             DateTime?
  startDate           DateTime?
  estimatedHours      Float?
  actualHours         Float?
  order               Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  comments            Comment[]
  documents           Document[]
  assignedTechnicians User[]     @relation("AssignedTasks")
  createdBy           User?      @relation("CreatedTasks", fields: [createdById], references: [id])
  phase               Phase?     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  site                Site?      @relation(fields: [siteId], references: [id])
  tenantId            Int?
  tenant              Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([createdById], map: "tasks_createdById_fkey")
  @@index([phaseId], map: "tasks_phaseId_fkey")
  @@index([siteId], map: "tasks_siteId_fkey")
  @@index([status])
  @@index([priority])
  @@index([tenantId])
  @@map("tasks")
}

model Intervention {
  id                  Int                @id @default(autoincrement())
  reference           String?            @unique
  type                InterventionType   @default(INCIDENT)
  status              InterventionStatus @default(DEMANDE)
  title               String
  description         String?            @db.Text
  manualLocation      String?            @db.Text
  siteId              Int?
  equipmentId         Int?
  requestedById       Int?
  report              String?            @db.Text
  startTime           DateTime?
  endTime             DateTime?
  slaDeadline         DateTime?
  slaBreached         Boolean            @default(false)
  clientValidated     Boolean            @default(false)
  signature           String?            @db.Text
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  priority            Priority           @default(NORMALE)
  billable            Boolean            @default(false)
  invoiceId           Int?
  technicalDetails    Json?
  comments            Comment[]
  documents           Document[]
  assignedTechnicians User[]             @relation("AssignedInterventions")
  equipment           Equipment?         @relation(fields: [equipmentId], references: [id])
  invoice             Invoice?           @relation(fields: [invoiceId], references: [id])
  requestedBy         User?              @relation("RequestedInterventions", fields: [requestedById], references: [id])
  site                Site?              @relation(fields: [siteId], references: [id])
  squadId             Int?
  squad               Squad?             @relation(fields: [squadId], references: [id])
  scheduledDate       DateTime?
  tenantId            Int?
  tenant              Tenant?            @relation(fields: [tenantId], references: [id])

  @@index([equipmentId], map: "interventions_equipmentId_fkey")
  @@index([invoiceId], map: "interventions_invoiceId_fkey")
  @@index([requestedById], map: "interventions_requestedById_fkey")
  @@index([siteId], map: "interventions_siteId_fkey")
  @@index([squadId], map: "interventions_squadId_fkey")
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([tenantId])
  @@map("interventions")
}

model Comment {
  id             Int           @id @default(autoincrement())
  content        String        @db.Text
  userId         Int
  taskId         Int?
  interventionId Int?
  isInternal     Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id])
  tenantId       Int?
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([interventionId], map: "comments_interventionId_fkey")
  @@index([taskId], map: "comments_taskId_fkey")
  @@index([userId], map: "comments_userId_fkey")
  @@index([tenantId])
  @@map("comments")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
  tenantId  Int?
  tenant    Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([userId], map: "notifications_userId_fkey")
  @@index([tenantId])
  @@map("notifications")
}

model Document {
  id             Int           @id @default(autoincrement())
  name           String
  type           DocumentType  @default(AUTRE)
  url            String
  mimeType       String?
  size           Int?
  uploadedById   Int?
  taskId         Int?
  interventionId Int?
  createdAt      DateTime      @default(now())
  intervention   Intervention? @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  task           Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy     User?         @relation(fields: [uploadedById], references: [id])
  tenantId       Int?
  tenant         Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([interventionId], map: "documents_interventionId_fkey")
  @@index([taskId], map: "documents_taskId_fkey")
  @@index([uploadedById], map: "documents_uploadedById_fkey")
  @@index([tenantId])
  @@map("documents")
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  userId    Int?
  action    AuditAction
  entity    String
  entityId  Int?
  oldValues String?     @db.LongText
  newValues String?     @db.LongText
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])
  tenantId  Int?
  tenant    Tenant?     @relation(fields: [tenantId], references: [id])

  @@index([userId], map: "audit_logs_userId_fkey")
  @@index([tenantId])
  @@map("audit_logs")
}

model MaintenanceSchedule {
  id           Int        @id @default(autoincrement())
  title        String
  description  String?    @db.Text
  frequency    Frequency  @default(MONTHLY)
  startDate    DateTime
  lastRunDate  DateTime?
  nextDueDate  DateTime
  status       String     @default("ACTIVE")
  siteId       Int
  equipmentId  Int?
  assignedToId Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  billable     Boolean    @default(false)
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  equipment    Equipment? @relation(fields: [equipmentId], references: [id])
  site         Site       @relation(fields: [siteId], references: [id])
  tenantId     Int?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([assignedToId], map: "maintenance_schedules_assignedToId_fkey")
  @@index([equipmentId], map: "maintenance_schedules_equipmentId_fkey")
  @@index([siteId], map: "maintenance_schedules_siteId_fkey")
  @@index([tenantId])
  @@map("maintenance_schedules")
}

model Invoice {
  id            Int            @id @default(autoincrement())
  number        String         @unique
  date          DateTime       @default(now())
  dueDate       DateTime
  clientId      Int
  status        InvoiceStatus  @default(BROUILLON)
  totalHT       Decimal        @db.Decimal(10, 2)
  tva           Decimal        @default(19.00) @db.Decimal(10, 2)
  totalTTC      Decimal        @db.Decimal(10, 2)
  notes         String?        @db.Text
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  interventions Intervention[]
  items         InvoiceItem[]
  client        Company        @relation("ClientInvoices", fields: [clientId], references: [id])
  tenantId      Int?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([clientId], map: "invoices_clientId_fkey")
  @@index([tenantId])
  @@map("invoices")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  description String
  quantity    Float   @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  totalPrice  Decimal @db.Decimal(10, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenantId    Int?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  @@index([invoiceId], map: "invoice_items_invoiceId_fkey")
  @@index([tenantId])
  @@map("invoice_items")
}

enum ProjectStatus {
  EN_COURS
  TERMINE
  ARCHIVE
}

enum Role {
  SUPER_ADMIN
  ADMIN
  DIRECTEUR
  CHEF_PROJET
  RESPONSABLE_TECHNIQUE
  TECHNICIEN
  CLIENT
  COMMERCIAL
  ACHETEUR
}

enum ContractStatus {
  ACTIF
  EXPIRE
  SUSPENDU
  EN_ATTENTE
}

enum SiteType {
  BATIMENT
  INFRASTRUCTURE
  EQUIPEMENT_INDUSTRIEL
  RESEAU
  AUTRE
}

enum EquipmentStatus {
  OPERATIONNEL
  EN_MAINTENANCE
  HORS_SERVICE
  EN_ATTENTE_PIECE
}

enum TaskStatus {
  BACKLOG
  A_FAIRE
  EN_COURS
  EN_REVISION
  TERMINE
  ANNULE
}

enum Priority {
  FAIBLE
  NORMALE
  HAUTE
  URGENTE
}

enum InterventionType {
  INCIDENT
  MAINTENANCE_PREVENTIVE
  MAINTENANCE_CORRECTIVE
  URGENCE
  INSPECTION
}

enum InterventionStatus {
  DEMANDE
  VALIDEE
  ASSIGNEE
  EN_COURS
  RAPPORT_SOUMIS
  VALIDATION_CLIENT
  CLOTUREE
  ANNULEE
}

enum NotificationType {
  TACHE_ASSIGNEE
  INTERVENTION_CREEE
  RETARD_SLA
  VALIDATION_CLIENT
  COMMENTAIRE
  STATUT_CHANGE
  RAPPORT_SOUMIS
  MEETING_REQUEST
  MEETING_SCHEDULED
  MEETING_REMINDER
  TASK_REMINDER
}

enum DocumentType {
  RAPPORT_INTERVENTION
  CONTRAT
  BON_INTERVENTION
  PHOTO
  MANUEL
  PLAN_TECHNIQUE
  AUTRE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
}

enum Frequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
}

enum InvoiceStatus {
  BROUILLON
  ENVOYE
  PAYE
  EN_RETARD
  ANNULE
}

model Squad {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?        @db.Text
  color         String?        @default("#3b82f6")
  leaderId      Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  leader        User?          @relation("SquadLeader", fields: [leaderId], references: [id])
  members       User[]         @relation("SquadMembers")
  interventions Intervention[]
  tenantId      Int?
  tenant        Tenant?        @relation(fields: [tenantId], references: [id])

  @@index([leaderId], map: "squads_leaderId_fkey")
  @@index([tenantId])
  @@map("squads")
}

model Meeting {
  id          Int           @id @default(autoincrement())
  title       String
  description String?       @db.Text
  startTime   DateTime?
  endTime     DateTime?
  location    String?       @db.Text
  videoLink   String?       @db.Text
  status      MeetingStatus @default(PENDING)
  type        MeetingType   @default(INTERNAL)
  notes       String?       @db.Text
  conclusion  String?       @db.Text

  createdById Int
  createdBy   User @relation("CreatedMeetings", fields: [createdById], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  siteId Int?
  site   Site? @relation(fields: [siteId], references: [id])

  clientId Int?
  client   Company? @relation(fields: [clientId], references: [id])

  participants User[] @relation("MeetingParticipants")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  Int?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([createdById], map: "meetings_createdById_fkey")
  @@index([projectId], map: "meetings_projectId_fkey")
  @@index([siteId], map: "meetings_siteId_fkey")
  @@index([clientId], map: "meetings_clientId_fkey")
  @@index([tenantId])
  @@map("meetings")
}

enum MeetingStatus {
  PENDING
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum MeetingType {
  INTERNAL
  CLIENT
}

enum PurchaseRequestStatus {
  SOUMISE
  VALIDEE_COMMERCIAL
  VALIDEE_DIRECTEUR
  EN_COURS_ACHAT
  TERMINEE
  REJETEE
}

model PurchaseRequest {
  id             Int                   @id @default(autoincrement())
  title          String
  description    String?               @db.Text
  justification  String?               @db.Text
  estimatedCost  Decimal?              @db.Decimal(10, 2)
  actualCost     Decimal?              @db.Decimal(10, 2)
  status         PurchaseRequestStatus @default(SOUMISE)
  priority       Priority              @default(NORMALE)
  comment        String?               @db.Text
  attachmentUrl  String?               @db.Text
  attachmentName String?               @db.Text

  requestedById Int
  requestedBy   User @relation("PurchaseRequestCreator", fields: [requestedById], references: [id])

  commercialValidatorId Int?
  commercialValidator   User? @relation("PurchaseRequestCommercialValidator", fields: [commercialValidatorId], references: [id])

  directorValidatorId Int?
  directorValidator   User? @relation("PurchaseRequestDirectorValidator", fields: [directorValidatorId], references: [id])

  purchasingAgentId Int?
  purchasingAgent   User? @relation("PurchaseRequestPurchaser", fields: [purchasingAgentId], references: [id])

  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id])

  siteId Int?
  site   Site? @relation(fields: [siteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenantId  Int?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([requestedById])
  @@index([commercialValidatorId])
  @@index([directorValidatorId])
  @@index([purchasingAgentId])
  @@index([projectId])
  @@index([siteId])
  @@index([tenantId])
  @@map("purchase_requests")
}

// ─────────────────────────────────────────────────────────────────────────────
// IMMOBILISATIONS (Fixed Assets)
// ─────────────────────────────────────────────────────────────────────────────

enum AssetCategory {
  INFORMATIQUE
  MOBILIER
  VEHICULE
  IMMOBILIER
  OUTILLAGE
  AUTRE
}

enum AssetStatus {
  EN_SERVICE
  EN_MAINTENANCE
  CEDE
  MISES_AU_REBUT
  EN_ATTENTE
}

enum AmortMethod {
  LINEAIRE
  DEGRESSIF
}

model FixedAsset {
  id                      Int               @id @default(autoincrement())
  code                    String            @unique
  designation             String
  category                AssetCategory     @default(AUTRE)
  status                  AssetStatus       @default(EN_SERVICE)
  acquisitionDate         DateTime
  acquisitionValue        Decimal           @db.Decimal(15, 3)
  residualValue           Decimal           @default(0) @db.Decimal(15, 3)
  usefulLifeYears         Int               @default(5)
  amortMethod             AmortMethod       @default(LINEAIRE)
  location                String?
  custodianId             Int?
  custodian               User?             @relation("AssetCustodian", fields: [custodianId], references: [id])
  supplier                String?
  invoiceRef              String?
  notes                   String?           @db.Text
  accumulatedDepreciation Decimal           @default(0) @db.Decimal(15, 3)
  netBookValue            Decimal           @db.Decimal(15, 3)
  currentYearDepreciation Decimal           @default(0) @db.Decimal(15, 3)
  siteId                  Int?
  site                    Site?             @relation(fields: [siteId], references: [id])
  amortizationLogs        AmortizationLog[]
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  tenantId                Int?
  tenant                  Tenant?           @relation(fields: [tenantId], references: [id])

  @@index([siteId])
  @@index([custodianId])
  @@index([tenantId])
  @@map("fixed_assets")
}

model AmortizationLog {
  id           Int        @id @default(autoincrement())
  fixedAssetId Int
  year         Int
  openingValue Decimal    @db.Decimal(15, 3)
  depreciation Decimal    @db.Decimal(15, 3)
  closingValue Decimal    @db.Decimal(15, 3)
  createdAt    DateTime   @default(now())
  fixedAsset   FixedAsset @relation(fields: [fixedAssetId], references: [id], onDelete: Cascade)
  tenantId     Int?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])

  @@index([fixedAssetId])
  @@index([tenantId])
  @@map("amortization_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// PARC AUTOMOBILE (Vehicle Fleet)
// ─────────────────────────────────────────────────────────────────────────────

enum VehicleStatus {
  DISPONIBLE
  EN_MISSION
  EN_MAINTENANCE
  HORS_SERVICE
  RESERVE
}

enum FuelType {
  DIESEL
  ESSENCE
  ELECTRIQUE
  HYBRIDE
  GPL
}

enum MissionStatus {
  PLANIFIEE
  EN_COURS
  TERMINEE
  ANNULEE
}

model Vehicle {
  id                   Int              @id @default(autoincrement())
  immatriculation      String           @unique
  marque               String
  modele               String
  annee                Int
  couleur              String?
  fuelType             FuelType         @default(DIESEL)
  status               VehicleStatus    @default(DISPONIBLE)
  kilometrage          Int              @default(0)
  prochainControleTech DateTime?
  prochainVidange      Int?
  assuranceExpiry      DateTime?
  visiteTechnique      DateTime?
  driverId             Int?
  driver               User?            @relation("VehicleDriver", fields: [driverId], references: [id])
  category             String?
  acquisitionDate      DateTime?
  acquisitionCost      Decimal?         @db.Decimal(12, 3)
  fuelBudgetMonthly    Decimal?         @db.Decimal(10, 3)
  notes                String?          @db.Text
  siteId               Int?
  site                 Site?            @relation(fields: [siteId], references: [id])
  fuelLogs             FuelLog[]
  missions             VehicleMission[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  tenantId             Int?
  tenant               Tenant?          @relation(fields: [tenantId], references: [id])

  @@index([siteId])
  @@index([driverId])
  @@index([tenantId])
  @@map("vehicles")
}

model FuelLog {
  id            Int      @id @default(autoincrement())
  vehicleId     Int
  date          DateTime
  liters        Decimal  @db.Decimal(8, 2)
  pricePerLiter Decimal  @db.Decimal(6, 3)
  totalCost     Decimal  @db.Decimal(10, 3)
  mileage       Int
  station       String?
  notes         String?  @db.Text
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  tenantId      Int?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([vehicleId])
  @@index([tenantId])
  @@map("fuel_logs")
}

model VehicleMission {
  id          Int           @id @default(autoincrement())
  vehicleId   Int
  driverId    Int
  driver      User          @relation("MissionDriver", fields: [driverId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  departure   String
  destination String
  purpose     String
  kmStart     Int
  kmEnd       Int?
  status      MissionStatus @default(PLANIFIEE)
  notes       String?       @db.Text
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tenantId    Int?
  tenant      Tenant?       @relation(fields: [tenantId], references: [id])

  @@index([vehicleId])
  @@index([driverId])
  @@index([tenantId])
  @@map("vehicle_missions")
}

// ─────────────────────────────────────────────────────────────────────────────
// MOYENS GÉNÉRAUX (General Services)
// ─────────────────────────────────────────────────────────────────────────────

enum ServiceRequestStatus {
  EN_ATTENTE
  EN_COURS
  RESOLU
  ANNULE
}

enum ServiceRequestPriority {
  FAIBLE
  NORMALE
  HAUTE
  URGENTE
}

enum ServiceCategory {
  NETTOYAGE
  SECURITE
  MAINTENANCE_BATIMENT
  IT
  TRANSPORT
  RESTAURATION
  AUTRE
}

enum SupplierContractStatus {
  ACTIF
  EXPIRE
  EN_NEGOCIATION
}

enum SpaceType {
  BUREAU
  SALLE_REUNION
  PARKING
  ENTREPOT
  CAFETERIA
  AUTRE
}

enum SpaceStatus {
  DISPONIBLE
  OCCUPE
  EN_MAINTENANCE
  RESERVE
}

model ServiceRequest {
  id            Int                    @id @default(autoincrement())
  reference     String                 @unique
  title         String
  description   String?                @db.Text
  category      ServiceCategory        @default(AUTRE)
  status        ServiceRequestStatus   @default(EN_ATTENTE)
  priority      ServiceRequestPriority @default(NORMALE)
  requestedBy   String
  department    String?
  location      String?
  assignedTo    String?
  estimatedCost Decimal?               @db.Decimal(10, 3)
  resolvedAt    DateTime?
  siteId        Int?
  site          Site?                  @relation(fields: [siteId], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  tenantId      Int?
  tenant        Tenant?                @relation(fields: [tenantId], references: [id])

  @@index([siteId])
  @@index([tenantId])
  @@map("service_requests")
}

model Supplier {
  id             Int                    @id @default(autoincrement())
  name           String
  type           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  rating         Decimal                @default(0) @db.Decimal(3, 1)
  contractStatus SupplierContractStatus @default(EN_NEGOCIATION)
  contractExpiry DateTime?
  monthlyBudget  Decimal?               @db.Decimal(10, 3)
  notes          String?                @db.Text
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  tenantId       Int?
  tenant         Tenant?                @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("suppliers")
}

model OfficeSupply {
  id            Int       @id @default(autoincrement())
  name          String
  category      String?
  currentStock  Int       @default(0)
  minStock      Int       @default(0)
  unit          String    @default("Unités")
  supplier      String?
  lastOrderDate DateTime?
  unitCost      Decimal?  @db.Decimal(8, 3)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenantId      Int?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("office_supplies")
}

model CompanySpace {
  id          Int         @id @default(autoincrement())
  name        String
  type        SpaceType   @default(BUREAU)
  capacity    Int?
  floor       String?
  status      SpaceStatus @default(DISPONIBLE)
  responsable String?
  notes       String?     @db.Text
  siteId      Int?
  site        Site?       @relation(fields: [siteId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenantId    Int?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])

  @@index([siteId])
  @@index([tenantId])
  @@map("company_spaces")
}
