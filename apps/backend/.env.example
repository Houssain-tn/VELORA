# --- SuiviTech PRO Environment Configuration ---

# Server
PORT=3333
NODE_ENV=development # development | production

# Database (MySQL via Prisma)
# Replace with your actual credentials
DATABASE_URL="mysql://root:@localhost:3306/suivitech"

# JWT Authentication
# GENERATE NEW SECRETS FOR PRODUCTION: openssl rand -base64 32
JWT_SECRET="PLEASE_CHANGE_ME_TO_A_SOLID_SECRET_KEY"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="PLEASE_CHANGE_ME_TO_A_SOLID_REFRESH_KEY"
JWT_REFRESH_EXPIRES_IN="7d"

# Security
# Comma-separated list of allowed origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5175"

# System Paths (Environment Specific)
# Example for Windows XAMPP: C:\\xampp\\mysql\\bin\\mysqldump.exe
# Example for Linux: /usr/bin/mysqldump
MYSQL_DUMP_PATH="C:\\xampp\\mysql\\bin\\mysqldump.exe"
